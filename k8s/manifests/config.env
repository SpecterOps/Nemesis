POSTGRES_EXPORTER_MEMORY_REQUEST="64Mi"
POSTGRES_EXPORTER_CPU_LIMIT="200m"
POSTGRES_EXPORTER_MEMORY_LIMIT="256Mi"

# =============================================================================
# Jupyter Stack (applied with --jupyter)
# =============================================================================
JUPYTER_IMAGE_TAG="latest"
JUPYTER_REPLICAS="1"
JUPYTER_PORT="8888"
JUPYTER_PASSWORD=""
JUPYTER_CPU_REQUEST="100m"
JUPYTER_MEMORY_REQUEST="256Mi"
JUPYTER_CPU_LIMIT="1"
JUPYTER_MEMORY_LIMIT="2Gi"

# =============================================================================
# LLM Stack (applied with --llm)
# =============================================================================
AGENTS_IMAGE_TAG="latest"
AGENTS_REPLICAS="1"
AGENTS_APP_PORT="8000"
AGENTS_MCP_PORT="5000"
AGENTS_WORKFLOW_RUNTIME_LOG_LEVEL="WARNING"
AGENTS_WORKFLOW_CLIENT_LOG_LEVEL="WARNING"
AGENTS_LITELLM_ADMIN_PASSWORD="admin123"
AGENTS_MAX_BUDGET="100"
AGENTS_BUDGET_DURATION="30d"
AGENTS_DOTNET_ANALYSIS_RUN_REQUEST_LIMIT="25"
AGENTS_DOTNET_ANALYSIS_RUN_TOKENS_LIMIT="1000000"
AGENTS_TRIAGE_CONSENSUS_THRESHOLD="3"
AGENTS_MCP_MAX_RESULTS="100"
AGENTS_CPU_REQUEST="250m"
AGENTS_MEMORY_REQUEST="512Mi"
AGENTS_CPU_LIMIT="2"
AGENTS_MEMORY_LIMIT="4Gi"

LITELLM_IMAGE="ghcr.io/berriai/litellm:v1.81.12-stable.1"
LITELLM_PORT="4000"
LITELLM_STORE_MODEL_IN_DB="True"
LITELLM_AWS_ACCESS_KEY_ID=""
LITELLM_AWS_SECRET_ACCESS_KEY=""
