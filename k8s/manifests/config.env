# =============================================================================
# Nemesis Raw Manifests Configuration
# =============================================================================
# This file is sourced by deploy.sh before envsubst processes the YAML files.
# All values use shell variable syntax: ${VAR_NAME}

# =============================================================================
# Namespace
# =============================================================================
NAMESPACE="nemesis"

# =============================================================================
# Global image settings
# =============================================================================
IMAGE_REGISTRY="ghcr.io/specterops/nemesis"
IMAGE_PULL_POLICY="IfNotPresent"
# For local k3d dev builds, override to:
# IMAGE_REGISTRY="k3d-nemesis-registry.localhost:5111"

# =============================================================================
# Credentials
# =============================================================================
POSTGRES_USER="nemesis"
POSTGRES_PASSWORD="Qwerty12345"
RABBITMQ_USER="nemesis"
RABBITMQ_PASSWORD="Qwerty12345"
S3_ACCESS_KEY_VALUE="nemesis"
S3_SECRET_KEY_VALUE="Qwerty12345"
HASURA_ADMIN_SECRET="pass456"
# Basic auth users for Traefik (htpasswd format). Default: n:n
BASIC_AUTH_USERS='n:$apr1$bcQYJ0ci$QLOjnsYcpoauiEZ5VcXBi/'
CHATBOT_DB_PASSWORD="chatbot_pass_change_me"

# =============================================================================
# Nemesis settings
# =============================================================================
NEMESIS_URL="https://localhost:7443/"
NEMESIS_PORT="7443"
LOG_LEVEL="INFO"
DEFAULT_EXPIRATION_DAYS="100"

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_IMAGE="postgres:18.1"
POSTGRES_DB="enrichment"
POSTGRES_PORT="5432"
POSTGRES_PARAMETERS="sslmode=disable"
POSTGRES_MAX_CONNECTIONS="300"
POSTGRES_SHARED_BUFFERS="1GB"
POSTGRES_SHARED_PRELOAD_LIBRARIES="pg_stat_statements"
POSTGRES_STORAGE_SIZE="20Gi"
POSTGRES_STORAGE_CLASS=""
POSTGRES_CPU_REQUEST="250m"
POSTGRES_MEMORY_REQUEST="512Mi"
POSTGRES_CPU_LIMIT="2"
POSTGRES_MEMORY_LIMIT="2Gi"

# =============================================================================
# PgBouncer
# =============================================================================
PGBOUNCER_IMAGE="public.ecr.aws/bitnami/pgbouncer:1.25.1"
PGBOUNCER_REPLICAS="1"
PGBOUNCER_PORT="5432"
PGBOUNCER_POOL_MODE="transaction"
PGBOUNCER_MAX_CLIENT_CONN="2000"
PGBOUNCER_DEFAULT_POOL_SIZE="60"
PGBOUNCER_MIN_POOL_SIZE="20"
PGBOUNCER_RESERVE_POOL_SIZE="15"
PGBOUNCER_CPU_REQUEST="50m"
PGBOUNCER_MEMORY_REQUEST="64Mi"
PGBOUNCER_CPU_LIMIT="500m"
PGBOUNCER_MEMORY_LIMIT="256Mi"

# =============================================================================
# RabbitMQ
# =============================================================================
RABBITMQ_IMAGE="rabbitmq:4.2.0-management"
RABBITMQ_HOSTNAME="rabbitmq-node"
RABBITMQ_STORAGE_SIZE="10Gi"
RABBITMQ_STORAGE_CLASS=""
RABBITMQ_CPU_REQUEST="250m"
RABBITMQ_MEMORY_REQUEST="512Mi"
RABBITMQ_CPU_LIMIT="1"
RABBITMQ_MEMORY_LIMIT="2Gi"

# =============================================================================
# SeaweedFS
# =============================================================================
SEAWEEDFS_IMAGE="chrislusf/seaweedfs:4.15"
SEAWEEDFS_BUCKETS="files loki-data"
SEAWEEDFS_STORAGE_SIZE="50Gi"
SEAWEEDFS_STORAGE_CLASS=""
SEAWEEDFS_CPU_REQUEST="250m"
SEAWEEDFS_MEMORY_REQUEST="512Mi"
SEAWEEDFS_CPU_LIMIT="1"
SEAWEEDFS_MEMORY_LIMIT="2Gi"

# =============================================================================
# Hasura
# =============================================================================
HASURA_IMAGE="hasura/graphql-engine:v2.48.6.cli-migrations-v2"
HASURA_LOG_LEVEL="warn"
HASURA_ENABLE_CONSOLE="true"
HASURA_CPU_REQUEST="100m"
HASURA_MEMORY_REQUEST="256Mi"
HASURA_CPU_LIMIT="1"
HASURA_MEMORY_LIMIT="1Gi"

# =============================================================================
# Traefik / Ingress
# =============================================================================
INGRESS_HOST=""
TLS_ENABLED="true"
TLS_SECRET_NAME="nemesis-tls-secret"

# =============================================================================
# Dapr
# =============================================================================
DAPR_SIDECAR_IMAGE="daprio/daprd:1.17.0"
DAPR_LOG_LEVEL="warn"
DAPR_PUBSUB_FILES_PREFETCH="100"
DAPR_PUBSUB_ALERTING_PREFETCH="25"
DAPR_PUBSUB_DOCCONV_PREFETCH="50"
DAPR_PUBSUB_DOTNET_PREFETCH="25"
DAPR_PUBSUB_DPAPI_PREFETCH="25"
DAPR_PUBSUB_TITUS_PREFETCH="100"
DAPR_PUBSUB_WORKFLOW_MONITOR_PREFETCH="25"

# =============================================================================
# Web API
# =============================================================================
WEB_API_IMAGE_TAG="latest"
WEB_API_REPLICAS="1"
WEB_API_PORT="8000"
WEB_API_CPU_REQUEST="100m"
WEB_API_MEMORY_REQUEST="256Mi"
WEB_API_CPU_LIMIT="1"
WEB_API_MEMORY_LIMIT="1Gi"

# =============================================================================
# File Enrichment
# =============================================================================
FILE_ENRICHMENT_IMAGE_TAG="latest"
FILE_ENRICHMENT_REPLICAS="1"
FILE_ENRICHMENT_PORT="8001"
FILE_ENRICHMENT_DAPR_LOG_LEVEL="warn"
FILE_ENRICHMENT_ENABLE_PII="false"
FILE_ENRICHMENT_PII_THRESHOLD="0.7"
FILE_ENRICHMENT_MAX_PARALLEL_WORKFLOWS="5"
FILE_ENRICHMENT_MAX_WORKFLOW_EXECUTION_TIME="300"
FILE_ENRICHMENT_CPU_REQUEST="500m"
FILE_ENRICHMENT_MEMORY_REQUEST="1Gi"
FILE_ENRICHMENT_CPU_LIMIT="2"
FILE_ENRICHMENT_MEMORY_LIMIT="4Gi"

# =============================================================================
# Document Conversion
# =============================================================================
DOCUMENT_CONVERSION_IMAGE_TAG="latest"
DOCUMENT_CONVERSION_REPLICAS="1"
DOCUMENT_CONVERSION_PORT="8000"
TIKA_CONFIG="/tika-config.xml"
TIKA_OCR_LANGUAGES="eng"
TIKA_USE_OCR="false"
DOCUMENT_CONVERSION_MAX_PARALLEL_WORKFLOWS="5"
DOCUMENT_CONVERSION_MAX_WORKFLOW_EXECUTION_TIME="300"
OMP_THREAD_LIMIT="1"
DOCUMENT_CONVERSION_CPU_REQUEST="500m"
DOCUMENT_CONVERSION_MEMORY_REQUEST="1Gi"
DOCUMENT_CONVERSION_CPU_LIMIT="2"
DOCUMENT_CONVERSION_MEMORY_LIMIT="4Gi"

# =============================================================================
# Titus Scanner
# =============================================================================
TITUS_SCANNER_IMAGE_TAG="latest"
TITUS_SCANNER_REPLICAS="1"
TITUS_SCANNER_PORT="8080"
TITUS_SCANNER_DAPR_MAX_CONCURRENCY="1"
TITUS_LOG_LEVEL="info"
TITUS_SNIPPET_LENGTH="512"
TITUS_MAX_CONCURRENT_FILES="2"
TITUS_MAX_MATCHES_PER_FILE="100"
TITUS_MAX_FILE_SIZE_MB="200"
TITUS_GOMEMLIMIT="1500MiB"
TITUS_EXTRACT_ARCHIVES="true"
TITUS_EXTRACT_MAX_FILE_SIZE_MB="10"
TITUS_EXTRACT_MAX_TOTAL_SIZE_MB="1000"
TITUS_EXTRACT_MAX_DEPTH="2"
TITUS_ENABLE_VALIDATION="false"
TITUS_VALIDATION_WORKERS="4"
TITUS_DISABLED_RULES="np.s3.1,np.s3.2,np.linkedin.3,kingfisher.jira.1"
TITUS_PUBSUB_NAME="titus"
TITUS_OUTPUT_TOPIC="titus_output"
TITUS_BULK_MAX_MESSAGES="100"
TITUS_BULK_MAX_AWAIT_DURATION_MS="1000"
TITUS_SCANNER_CPU_REQUEST="500m"
TITUS_SCANNER_MEMORY_REQUEST="1Gi"
TITUS_SCANNER_CPU_LIMIT="1"
TITUS_SCANNER_MEMORY_LIMIT="2Gi"

# =============================================================================
# .NET Service
# =============================================================================
DOTNET_SERVICE_IMAGE_TAG="latest"
DOTNET_SERVICE_REPLICAS="1"
DOTNET_SERVICE_PORT="5000"
DOTNET_SERVICE_DAPR_MAX_CONCURRENCY="1"
DOTNET_SERVICE_CPU_REQUEST="100m"
DOTNET_SERVICE_MEMORY_REQUEST="256Mi"
DOTNET_SERVICE_CPU_LIMIT="1"
DOTNET_SERVICE_MEMORY_LIMIT="1Gi"

# =============================================================================
# Alerting
# =============================================================================
ALERTING_IMAGE_TAG="latest"
ALERTING_REPLICAS="1"
ALERTING_PORT="8000"
APPRISE_URLS=""
ALERTING_CPU_REQUEST="100m"
ALERTING_MEMORY_REQUEST="256Mi"
ALERTING_CPU_LIMIT="500m"
ALERTING_MEMORY_LIMIT="512Mi"

# =============================================================================
# Housekeeping
# =============================================================================
HOUSEKEEPING_IMAGE_TAG="latest"
HOUSEKEEPING_REPLICAS="1"
CLEANUP_SCHEDULE="*/3 * * * *"
HOUSEKEEPING_CPU_REQUEST="100m"
HOUSEKEEPING_MEMORY_REQUEST="128Mi"
HOUSEKEEPING_CPU_LIMIT="500m"
HOUSEKEEPING_MEMORY_LIMIT="512Mi"

# =============================================================================
# Gotenberg
# =============================================================================
GOTENBERG_IMAGE="gotenberg/gotenberg:8.21.1"
GOTENBERG_REPLICAS="1"
GOTENBERG_PORT="3000"
GOTENBERG_API_TIMEOUT="180s"
GOTENBERG_LIBREOFFICE_RESTART_AFTER="5"
GOTENBERG_CPU_REQUEST="100m"
GOTENBERG_MEMORY_REQUEST="256Mi"
GOTENBERG_CPU_LIMIT="1"
GOTENBERG_MEMORY_LIMIT="1Gi"

# =============================================================================
# Frontend
# =============================================================================
FRONTEND_IMAGE_TAG="latest"
FRONTEND_REPLICAS="1"
FRONTEND_PORT="3000"
FRONTEND_CPU_REQUEST="50m"
FRONTEND_MEMORY_REQUEST="128Mi"
FRONTEND_CPU_LIMIT="500m"
FRONTEND_MEMORY_LIMIT="512Mi"

# =============================================================================
# KEDA Autoscaling
# =============================================================================
AUTOSCALING_ENABLED="true"

KEDA_FILE_ENRICHMENT_ENABLED="true"
KEDA_FILE_ENRICHMENT_MIN_REPLICAS="1"
KEDA_FILE_ENRICHMENT_MAX_REPLICAS="5"
KEDA_FILE_ENRICHMENT_COOLDOWN="60"
KEDA_FILE_ENRICHMENT_POLLING="15"
KEDA_FILE_ENRICHMENT_QUEUE_LENGTH="10"
KEDA_FILE_ENRICHMENT_QUEUE_NAME="files-new_file"

KEDA_DOCUMENT_CONVERSION_ENABLED="true"
KEDA_DOCUMENT_CONVERSION_MIN_REPLICAS="1"
KEDA_DOCUMENT_CONVERSION_MAX_REPLICAS="5"
KEDA_DOCUMENT_CONVERSION_COOLDOWN="60"
KEDA_DOCUMENT_CONVERSION_POLLING="15"
KEDA_DOCUMENT_CONVERSION_QUEUE_LENGTH="5"
KEDA_DOCUMENT_CONVERSION_QUEUE_NAME="files-document_conversion_input"

KEDA_TITUS_SCANNER_ENABLED="true"
KEDA_TITUS_SCANNER_MIN_REPLICAS="1"
KEDA_TITUS_SCANNER_MAX_REPLICAS="5"
KEDA_TITUS_SCANNER_COOLDOWN="60"
KEDA_TITUS_SCANNER_POLLING="15"
KEDA_TITUS_SCANNER_QUEUE_LENGTH="10"
KEDA_TITUS_SCANNER_QUEUE_NAME="titus-titus_input"

KEDA_DOTNET_SERVICE_ENABLED="true"
KEDA_DOTNET_SERVICE_MIN_REPLICAS="1"
KEDA_DOTNET_SERVICE_MAX_REPLICAS="3"
KEDA_DOTNET_SERVICE_COOLDOWN="60"
KEDA_DOTNET_SERVICE_POLLING="15"
KEDA_DOTNET_SERVICE_QUEUE_LENGTH="5"
KEDA_DOTNET_SERVICE_QUEUE_NAME="dotnet-dotnet_input"

KEDA_GOTENBERG_ENABLED="true"
KEDA_GOTENBERG_MIN_REPLICAS="1"
KEDA_GOTENBERG_MAX_REPLICAS="3"
KEDA_GOTENBERG_COOLDOWN="120"
KEDA_GOTENBERG_POLLING="15"
KEDA_GOTENBERG_CPU_THRESHOLD="70"
KEDA_GOTENBERG_SCALE_UP_STABILIZATION="30"
KEDA_GOTENBERG_SCALE_DOWN_STABILIZATION="30"

# =============================================================================
# Monitoring Stack (applied with --monitoring)
# =============================================================================
MONITORING_ENABLED="false"

PROMETHEUS_IMAGE="prom/prometheus:v3.10.0"
PROMETHEUS_PORT="9090"
PROMETHEUS_STORAGE_SIZE="10Gi"
PROMETHEUS_STORAGE_CLASS=""
PROMETHEUS_CPU_REQUEST="250m"
PROMETHEUS_MEMORY_REQUEST="512Mi"
PROMETHEUS_CPU_LIMIT="1"
PROMETHEUS_MEMORY_LIMIT="2Gi"

GRAFANA_IMAGE="grafana/grafana:12.3.4"
GRAFANA_PORT="3000"
GRAFANA_STORAGE_SIZE="5Gi"
GRAFANA_STORAGE_CLASS=""
GRAFANA_ANONYMOUS_ENABLED="true"
GRAFANA_ANONYMOUS_ORG_ROLE="Editor"
GRAFANA_CPU_REQUEST="100m"
GRAFANA_MEMORY_REQUEST="256Mi"
GRAFANA_CPU_LIMIT="500m"
GRAFANA_MEMORY_LIMIT="512Mi"

LOKI_IMAGE="grafana/loki:3.5.11"
LOKI_PORT="3100"
