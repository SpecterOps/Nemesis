LITELLM_ADMIN_PASSWORD="admin123"
LITELLM_CPU_REQUEST="100m"
LITELLM_MEMORY_REQUEST="256Mi"
LITELLM_CPU_LIMIT="1"
LITELLM_MEMORY_LIMIT="1Gi"

PHOENIX_IMAGE="arizephoenix/phoenix:13.3.0"
PHOENIX_PORT="6006"
PHOENIX_STORAGE_SIZE="5Gi"
PHOENIX_STORAGE_CLASS=""
PHOENIX_RETENTION_POLICY_DAYS="100"
PHOENIX_CPU_REQUEST="100m"
PHOENIX_MEMORY_REQUEST="256Mi"
PHOENIX_CPU_LIMIT="1"
PHOENIX_MEMORY_LIMIT="1Gi"
