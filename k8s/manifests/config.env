LOKI_MEMORY_LIMIT="1Gi"

PROMTAIL_IMAGE="grafana/promtail:3.5.11"
PROMTAIL_CPU_REQUEST="50m"
PROMTAIL_MEMORY_REQUEST="64Mi"
PROMTAIL_CPU_LIMIT="200m"
PROMTAIL_MEMORY_LIMIT="256Mi"

JAEGER_IMAGE="jaegertracing/jaeger:2.15.1"
JAEGER_PORT="16686"
JAEGER_STORAGE_SIZE="10Gi"
JAEGER_STORAGE_CLASS=""
JAEGER_CPU_REQUEST="250m"
JAEGER_MEMORY_REQUEST="512Mi"
JAEGER_CPU_LIMIT="1"
JAEGER_MEMORY_LIMIT="2Gi"

OTEL_COLLECTOR_IMAGE="otel/opentelemetry-collector:0.139.0"
OTEL_COLLECTOR_CPU_REQUEST="100m"
OTEL_COLLECTOR_MEMORY_REQUEST="128Mi"
OTEL_COLLECTOR_CPU_LIMIT="500m"
OTEL_COLLECTOR_MEMORY_LIMIT="512Mi"

NODE_EXPORTER_IMAGE="prom/node-exporter:v1.10.2"
NODE_EXPORTER_PORT="9100"
NODE_EXPORTER_CPU_REQUEST="50m"
NODE_EXPORTER_MEMORY_REQUEST="64Mi"
NODE_EXPORTER_CPU_LIMIT="200m"
NODE_EXPORTER_MEMORY_LIMIT="256Mi"

POSTGRES_EXPORTER_IMAGE="prometheuscommunity/postgres-exporter:v0.18.1"
POSTGRES_EXPORTER_PORT="9187"
